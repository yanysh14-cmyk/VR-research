                          src={task.image} 
                          alt={task.title}
                          className="w-full h-full object-cover"
                        />
                     </motion.div>
                  </motion.div>

                  {/* Interaction Hint */}
                  <motion.div
                    initial={{ opacity: 0 }}
                    animate={{ opacity: hasInteracted ? 0 : 1 }}
                    transition={{ duration: 0.5, delay: 0.5 }} // Small delay on mount, immediate fade out
                    className="absolute bottom-4 right-8 z-30 pointer-events-none"
                  >
                    <span className="text-[10px] font-bold uppercase tracking-wider text-slate-300 hidden md:block">
                      Hover to preview
                    </span>
                    <span className="text-[10px] font-bold uppercase tracking-wider text-slate-300 md:hidden block">
                      Tap to preview
                    </span>
                  </motion.div>

                  {/* Text Content (Right) */}
                  <div className="flex-grow flex flex-col p-8 h-full relative z-20">
                    <h3 className="text-xl font-bold text-slate-900 mb-3 group-hover:text-purple-700 transition-colors">
                      {task.title}
                    </h3>
                    
                    <div className="flex-grow overflow-hidden">
                      <p className="text-base font-medium text-slate-600 leading-relaxed mb-2">
                        {task.desc}
                      </p>
                      <p className="text-sm text-slate-400 font-medium italic">
                        {task.citation}
                      </p>
                    </div>
                    
                    <div className="mt-auto pt-4 border-t border-slate-200/60 flex items-center justify-between">
                      <span className="text-xs font-bold uppercase tracking-wider text-slate-500 group-hover:text-purple-600 transition-colors">
                        {task.meta}
                      </span>
                    </div>
                  </div>
                </motion.div>
              );
            })}
          </div>
        </div>
      </Container>
    </section>
  );
}
