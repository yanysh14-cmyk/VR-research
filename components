const sequence = [
  { type: 'state', label: "Entry", duration: "3s", color: "bg-slate-800 text-white" },
  { type: 'rating', label: "Baseline Ratings", duration: "12s" },
  { type: 'task', icon: Eye, title: "Passive View", duration: "~1 min", color: "bg-blue-50 text-blue-600 border-blue-200" },
  { type: 'rating', label: "Ratings", duration: "12s" },
  { type: 'task', icon: Sigma, title: "Prob. Learning", duration: "~2:30", color: "bg-indigo-50 text-indigo-600 border-indigo-200" },
  { type: 'rating', label: "Ratings", duration: "12s" },
  { type: 'task', icon: Scale, title: "Mixed Gamble", duration: "~2:30", color: "bg-violet-50 text-violet-600 border-violet-200" },
  { type: 'rating', label: "Ratings", duration: "12s" },
  { type: 'task', icon: Coins, title: "Delay Discount", duration: "~2:00", color: "bg-purple-50 text-purple-600 border-purple-200" },
  { type: 'rating', label: "Ratings", duration: "12s" },
  { type: 'task', icon: MapPin, title: "BART", duration: "~3:00", color: "bg-fuchsia-50 text-fuchsia-600 border-fuchsia-200" },
  { type: 'rating', label: "Ratings", duration: "12s" },
];

export function ExperimentFlow() {
  const scrollRef = useRef<HTMLDivElement>(null);
  const [showScrollHint, setShowScrollHint] = useState(false);
  const [highlightBart, setHighlightBart] = useState(false);
  const bartRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    const card = bartRef.current;
    if (!card) return;

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          // Once visible, wait 3 seconds then highlight
          const timer = setTimeout(() => {
            setHighlightBart(true);
          }, 3000);
          
          observer.disconnect(); // Only trigger once
        }
      },
      { threshold: 0.5 }
    );

    observer.observe(card);
    return () => observer.disconnect();
  }, []);

  useEffect(() => {
    const scrollContainer = scrollRef.current;
    if (!scrollContainer) return;

    const checkScroll = () => {
      const { scrollLeft, scrollWidth, clientWidth } = scrollContainer;
      // Show hint if there is scrollable content to the right (> 50px remaining)
      // and the content is actually scrollable (scrollWidth > clientWidth)
      const isScrollable = scrollWidth > clientWidth;
      const remaining = scrollWidth - (scrollLeft + clientWidth);
      
      setShowScrollHint(isScrollable && remaining > 50);
    };

    // Check immediately and on resize/scroll
    checkScroll();
    scrollContainer.addEventListener('scroll', checkScroll);
    window.addEventListener('resize', checkScroll);

    return () => {
      scrollContainer.removeEventListener('scroll', checkScroll);
      window.removeEventListener('resize', checkScroll);
    };
  }, []);

  useEffect(() => {
    const scrollContainer = scrollRef.current;
    if (!scrollContainer) return;

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          // Subtle auto-scroll hint on first view
          const hasScrolled = sessionStorage.getItem('experimentFlowScrolled');
          if (!hasScrolled) {
            setTimeout(() => {
              scrollContainer.scrollTo({ left: 120, behavior: 'smooth' });
              setTimeout(() => {
                scrollContainer.scrollTo({ left: 0, behavior: 'smooth' });
                sessionStorage.setItem('experimentFlowScrolled', 'true');
              }, 1200);
            }, 1000);
          }
          observer.disconnect();
        }
      },
      { threshold: 0.3 }
    );

    observer.observe(scrollContainer);
    return () => observer.disconnect();
  }, []);

  return (
    <section className="py-20 bg-slate-50 overflow-hidden">
      <Container>
        <div className="mb-12 text-center">
          <h2 className="text-3xl font-bold text-slate-900 mb-4">Experiment Protocol</h2>
          <p className="text-slate-600 max-w-2xl mx-auto">
            Each participant completes three blocks (Warm, Neutral, Cold). Within each block, a fixed sequence of tasks and ratings is strictly enforced.
          </p>
        </div>

        {/* Main Container Card */}
        <div className="bg-white rounded-3xl shadow-xl border border-slate-100 p-8 lg:p-12 relative">
          
          {/* Top Header Row */}
          <div className="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-6 border-b border-slate-100 pb-8">
            <div>
              <h3 className="text-2xl font-bold text-slate-900 flex items-center gap-3">
                Single Block Flow
                <span className="bg-purple-100 text-purple-700 text-xs px-2 py-1 rounded-full font-bold uppercase tracking-wide">~12 min</span>
              </h3>
              <p className="text-slate-500 text-xs mt-1 font-medium">
                Order rule: Hot/Cold start randomized; Neutral is always the middle block.
              </p>
            </div>
            
            <div className="flex flex-col items-end gap-2">
              <div className="text-xs font-semibold text-slate-400 uppercase tracking-wider">Design</div>
              <div className="flex gap-2">
                <span className="bg-slate-100 text-slate-600 px-3 py-1.5 rounded-lg text-sm font-medium border border-slate-200">
                  Within-Subjects
                </span>
              </div>
            </div>
          </div>

          {/* Diagram Area - Scrollable */}
          <div className="relative">
            <div 
              ref={scrollRef}
              className="relative w-full overflow-x-auto pb-4 hide-scrollbar"
            >
              <div className="min-w-max flex items-center gap-3 py-4 px-2">
              
              {/* Start Node */}
              <div className="flex flex-col items-center gap-2">
                <div className="w-10 h-10 rounded-full bg-slate-900 text-white flex items-center justify-center shadow-lg z-10">
                  <Play className="w-4 h-4 fill-current" />
                </div>
                <div className="text-[10px] font-bold text-slate-400 uppercase">Start</div>
              </div>

              {/* Connector */}
              <div className="w-6 h-0.5 bg-slate-200"></div>

              {/* Sequence Loop */}
              {sequence.map((item, idx) => (
                <div key={idx} className="flex items-center gap-3">
                  
                  {/* Item Render */}
                  {item.type === 'state' && (
                    <div className={`${item.color} px-4 py-2 rounded-xl text-xs font-bold shadow-md`}>
                      {item.label} <span className="opacity-70 ml-1">({item.duration})</span>
                    </div>
                  )}

                  {item.type === 'rating' && (
                    <div className="flex flex-col items-center gap-1 group">
                      <div className="flex flex-col gap-1.5">
                        <div className="bg-slate-100 border border-slate-200 text-slate-500 px-2 py-1 rounded text-[9px] font-bold uppercase tracking-wide group-hover:bg-purple-50 group-hover:text-purple-600 group-hover:border-purple-200 transition-colors cursor-default min-w-[50px] text-center">
                          TSV 6s
                        </div>
                        <div className="bg-slate-100 border border-slate-200 text-slate-500 px-2 py-1 rounded text-[9px] font-bold uppercase tracking-wide group-hover:bg-purple-50 group-hover:text-purple-600 group-hover:border-purple-200 transition-colors cursor-default min-w-[50px] text-center">
                          TCV 6s
                        </div>
                      </div>
                    </div>
                  )}

                  {item.type === 'task' && (
                    <motion.div 
                      ref={item.title === "BART" ? bartRef : undefined}
                      whileHover={{ y: -2 }}
                      className={`flex flex-col items-center justify-center w-28 h-24 rounded-xl border-2 ${item.color} bg-white shadow-sm p-2 relative transition-all duration-700 ${item.title === "BART" && highlightBart ? "ring-2 ring-fuchsia-300 ring-offset-2 shadow-[0_0_20px_rgba(232,121,249,0.4)]" : ""}`}
                    >
                      {item.icon && <item.icon className="w-6 h-6 mb-2 opacity-80" />}
                      <div className="text-xs font-bold text-center leading-tight text-slate-900">{item.title}</div>
                      <div className="text-[10px] mt-1 font-medium opacity-70">{item.duration}</div>
                      
                      {/* Connection Dots */}
                      <div className="absolute -left-1.5 top-1/2 w-3 h-3 bg-white border-2 border-slate-200 rounded-full transform -translate-y-1/2"></div>
                      <div className="absolute -right-1.5 top-1/2 w-3 h-3 bg-white border-2 border-slate-200 rounded-full transform -translate-y-1/2"></div>

                      {/* Fixed Time Label */}
                      {item.title === "BART" && (
                        <AnimatePresence>
                          {highlightBart && (
                            <motion.div
                              initial={{ opacity: 0, scale: 0.9, y: 5 }}
                              animate={{ opacity: 1, scale: 1, y: 0 }}
                              className="absolute -top-3 -right-4 bg-fuchsia-100 text-fuchsia-700 text-[9px] font-bold px-2 py-0.5 rounded-full shadow-sm border border-fuchsia-200 whitespace-nowrap z-10"
                            >
                              Fixed time
                            </motion.div>
                          )}
                        </AnimatePresence>
                      )}
                    </motion.div>
                  )}

                  {/* Connector Line to Next (unless last) */}
                  {idx < sequence.length - 1 && (
                    <div className="w-4 h-0.5 bg-slate-200"></div>
                  )}
                </div>
              ))}

              {/* End Connector */}
              <div className="w-6 h-0.5 bg-slate-200"></div>

              {/* End Node */}
              <div className="flex flex-col items-center gap-2">
                <div className="w-10 h-10 rounded-full bg-slate-100 border-2 border-slate-300 text-slate-400 flex items-center justify-center z-10">
                  <RefreshCw className="w-4 h-4" />
                </div>
                <div className="text-[10px] font-bold text-slate-400 uppercase">Next Env</div>
              </div>

              </div>

            </div>

            {/* Scroll Hint Overlay */}
            <motion.div 
              initial={{ opacity: 0 }}
              animate={{ opacity: showScrollHint ? 1 : 0 }}
              transition={{ duration: 0.5, ease: "easeInOut" }}
              className="absolute right-0 top-1/2 -translate-y-1/2 z-20 flex items-center gap-2 pointer-events-none pr-2 bg-gradient-to-l from-white via-white/90 to-transparent py-8 pl-12"
            >
              <span className="text-xs font-bold text-slate-400 uppercase tracking-wider hidden sm:inline-block">Scroll</span>
              <motion.div
                animate={{ x: [0, 6, 0], opacity: [0.6, 1, 0.6] }}
                transition={{ 
                  duration: 2, 
                  ease: "easeInOut", 
                  repeat: Infinity, 
                  repeatDelay: 5 
                }}
              >
                <ArrowRight className="w-5 h-5 text-slate-400" />
              </motion.div>
            </motion.div>
          </div>
          
        </div>
        {/* Explanation Card */}
        <AnimatePresence>
          {highlightBart && (
            <motion.div 
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: 20 }}
              transition={{ duration: 0.8, ease: "easeOut" }}
              className="max-w-xl mx-auto bg-white rounded-2xl border border-slate-100 p-6 shadow-sm mt-8"
            >
              <h4 className="text-sm font-bold text-slate-800 mb-4 flex items-center gap-2">
                <Clock className="w-4 h-4 text-fuchsia-500" />
                Why fixed durations?
              </h4>
              <ul className="space-y-2.5">
                <li className="flex items-start gap-3 text-sm text-slate-600">
                  <span className="w-1.5 h-1.5 rounded-full bg-slate-300 mt-1.5 shrink-0" />
                  <span>Same exposure time across environments → fair comparisons.</span>
                </li>
                <li className="flex items-start gap-3 text-sm text-slate-600">
                  <span className="w-1.5 h-1.5 rounded-full bg-slate-300 mt-1.5 shrink-0" />
                  <span>Probe timing is consistent for TSV/TCV + skin temperature.</span>
                </li>
                <li className="flex items-start gap-3 text-sm text-slate-600">
                  <span className="w-1.5 h-1.5 rounded-full bg-fuchsia-300 mt-1.5 shrink-0" />
                  <span>BART is time-fixed because pacing varies across people.</span>
                </li>
              </ul>
            </motion.div>
          )}
        </AnimatePresence>
      </Container>
    </section>
  );
}

