              return (
                <motion.div
                  key={idx}
                  initial={{ opacity: 0, y: 12 }}
                  whileInView={{ opacity: 1, y: 0 }}
                  viewport={{ once: true, margin: "-50px" }}
                  transition={{ delay: idx * 0.1, duration: 0.6, ease: "easeOut" }}
                  whileHover="hover"
                  animate={isActive ? "hover" : undefined}
                  onClick={() => handleCardClick(idx)}
                  onMouseEnter={handleInteraction}
                  variants={{
                    idle: { y: 0, scale: 1 },
                    hover: { 
                      y: -8, 
                      scale: 1.02,
                      boxShadow: "0 10px 30px -10px rgba(139, 92, 246, 0.2)", // soft lilac glow
                      transition: { type: "spring", stiffness: 300, damping: 20 }
                    }
                  }}
                  className={`
                    group relative flex overflow-hidden rounded-3xl border-2 transition-colors duration-300 cursor-pointer h-[380px]
                    ${task.theme.bg} ${task.theme.border} ${task.theme.hoverBorder} hover:shadow-xl ${task.theme.shadow}
                  `}
                >
                  {/* Image Panel (Left) */}
                  <motion.div
                    variants={{
                      idle: { width: "0%" },
                      hover: { width: "45%" }
                    }}
                    transition={{ type: "spring", stiffness: 200, damping: 25 }}
                    className="relative h-full flex-shrink-0 overflow-hidden"
                  >
                     <motion.div
                        variants={{
                            idle: { opacity: 0, scale: 1.1 },
                            hover: { opacity: 1, scale: 1 }
